<?xml version="1.0" encoding="utf-8"?>
<!-- جعل شاشة البدء مطابقة تماماً لشاشة الترحيب -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- لون الخلفية الداكن المطابق لثيم التطبيق -->
    <item android:drawable="#0F172A" />

    <!-- وضع الشعار في المنتصف ليكون هو نفسه شعار شاشة الترحيب -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@mipmap/ic_launcher" />
    </item>
</layer-list>
