rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- الدوال المساعدة ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // دالة الأدمن المتطورة (تتحقق من الرتبة في مستند المستخدم)
    function isAdmin() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true ||
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') in ['admin', 'owner', 'developer', 'manager']
             );
    }

    // --- 1. الإعدادات والبيانات العامة (لضمان استقرار الإقلاع) ---
    match /system_settings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /app_texts/{id} { allow read: if true; allow write: if isAdmin(); }
    match /announcements/{id} { allow read: if true; allow write: if isAdmin(); }
    match /global_announcements/{id} { allow read: if true; allow write: if isAdmin(); }
    match /meta/{id} { allow read: if true; }

    // --- 2. المتاجر والسلع والتأثيرات (يجب أن يراها الجميع) ---
    match /gifts/{id} { allow read: if true; allow write: if isAdmin(); }
    match /frames/{id} { allow read: if true; allow write: if isAdmin(); }
    match /bubbles/{id} { allow read: if true; allow write: if isAdmin(); }
    match /covers/{id} { allow read: if true; allow write: if isAdmin(); }
    match /entry_effects/{id} { allow read: if true; allow write: if isAdmin(); }
    match /mic_styles/{id} { allow read: if true; allow write: if isAdmin(); }
    match /recharge_plans/{id} { allow read: if true; allow write: if isAdmin(); }
    match /store_items/{id} { allow read: if true; allow write: if isAdmin(); }
    match /store_packages/{id} { allow read: if true; allow write: if isAdmin(); }
    match /gem_bundles/{id} { allow read: if true; allow write: if isAdmin(); }
    match /themes/{id} { allow read: if true; allow write: if isAdmin(); }
    match /room_themes/{id} { allow read: if true; allow write: if isAdmin(); }
    match /vehicles/{id} { allow read: if true; allow write: if isAdmin(); }
    match /badges_templates/{id} { allow read: if true; allow write: if isAdmin(); }
    match /levels/{id} { allow read: if true; }
    match /store_levels/{id} { allow read: if true; }

    // --- 3. المستخدمون (الحماية والبيانات الشخصية) ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOwner(userId) || isAdmin();

      match /{allSub=**} {
        allow read: if isOwner(userId) || isAdmin() || isSignedIn();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // --- 4. التواصل الاجتماعي (المنشورات، اليوميات، اللحظات) ---
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasAny(['likes', 'commentCount', 'sharesCount']));
      allow delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();

      match /comments/{id} { allow read, write: if isSignedIn(); }
    }

    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      match /replies/{id} { allow read, write: if isSignedIn(); }
    }

    match /moments/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /daily_posts/{id} { allow read, write: if isSignedIn(); }

    // --- 5. الرسائل والمحادثات والغرف (حل مشكلة الاختفاء) ---
    match /chatRooms/{id} {
      allow read, write: if isSignedIn();
      match /{all=**} { allow read, write: if isSignedIn(); }
    }
    match /chats/{id} {
      allow read, write: if isSignedIn();
      match /{all=**} { allow read, write: if isSignedIn(); }
    }
    match /messages/{id} {
      allow read, write: if isSignedIn();
      match /{all=**} { allow read, write: if isSignedIn(); }
    }
    match /conversations/{id} { allow read, write: if isSignedIn(); }
    match /rooms/{roomId} {
      allow read: if true;
      allow write: if isSignedIn();
      
      // قواعد خاصة بالمايكات (mic_seats) - توفير التكلفة
      match /mic_seats/{seatId} {
        allow read: if true;
        // السماح بالإنشاء والتحديث والحذف للمستخدمين المسجلين
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }
      
      // قواعد خاصة بالمستخدمين المتصلين (online_users)
      match /online_users/{userId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
        allow update: if isSignedIn() && request.resource.data.uid == request.auth.uid;
        allow delete: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      }
      
      // قواعد خاصة بالدردشة في الغرفة
      match /chat/{messageId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
      
      match /{all=**} { allow read, write: if isSignedIn(); }
    }

    // --- 6. الاقتصاد والعملات والمحفظة ---
    match /payments/{id} { allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()); allow create: if isSignedIn(); }
    match /purchases/{id} { allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()); allow create: if isSignedIn(); }
    match /investments/{id} { allow read, write: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()); }
    match /reward_transactions/{id} { allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()); }
    match /harvest_transactions/{id} { allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()); }
    match /agent_transactions/{id} { allow read: if isSignedIn(); }

    // --- 7. الألعاب والفعاليات والـ PK ---
    match /games/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /pk_battles/{id} { allow read, write: if isSignedIn(); }
    match /pk_random_matches/{id} { allow read, write: if isSignedIn(); }
    match /room_battles/{id} { allow read, write: if isSignedIn(); }
    match /ludo_online/{id} { allow read, write: if isSignedIn(); }
    match /tournaments/{id} { allow read: if true; allow write: if isAdmin(); }

    // --- 8. العائلات والعلاقات ---
    match /families/{id} {
      allow read: if true;
      allow write: if isSignedIn();
      match /{all=**} { allow read, write: if isSignedIn(); }
    }
    match /friends/{id} { allow read, write: if isSignedIn(); }
    match /follows/{id} { allow read, write: if isSignedIn(); }
    match /followers/{id} { allow read, write: if isSignedIn(); }
    match /friendships/{id} { allow read, write: if isSignedIn(); }
    match /friend_requests/{id} { allow read, write: if isSignedIn(); }

    // --- 9. الإدارة والرقابة ---
    match /admin_config/{id} { allow read, write: if isAdmin(); }
    match /admin_logs/{id} { allow read, write: if isAdmin(); }
    match /audit_logs/{id} { allow read, write: if isAdmin(); }
    match /reports/{id} { allow read: if isAdmin(); allow create: if isSignedIn(); }
    match /banned_users/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /agencies/{id} { allow read: if true; allow write: if isAdmin(); }

    // --- 10. قاعدة عامة نهائية ---
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
