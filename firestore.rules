rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default security: Deny all reads and writes by default.
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Users Collection
    // READ: Anyone can read public profile data.
    // WRITE: A user can only update their own data.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // 2. Chat Rooms Collection
    // READ/WRITE: Only participants of the chat room can access it.
    match /chatRooms/{roomId} {
      allow read, write: if request.auth.uid in resource.data.participants;

      // Messages Subcollection
      // READ: Only participants can read messages.
      // CREATE: Sender must be the authenticated user and a participant.
      // UPDATE/DELETE: Only sender can edit/delete their own message (handled by logic).
      match /messages/{messageId} {
        allow read: if request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants;
        allow create: if request.auth.uid == request.resource.data.senderId &&
                       request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants;
        allow update, delete: if request.auth.uid == resource.data.senderId; 
      }
    }

    // 3. Voice Rooms Collection
    // READ: Any authenticated user can see the rooms.
    // UPDATE: Only the owner or a moderator can change room settings.
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow update: if request.auth.uid == resource.data.ownerId || request.auth.uid in resource.data.moderators;

      // Subcollections (chat, online_users, mic_seats, etc.)
      // Allow users who are present in the room to interact.
      match /online_users/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == userId; // Users can add/remove themselves
      }

      match /chat/{messageId} {
        allow read: if request.auth != null; 
        allow create: if request.auth.uid == request.resource.data.senderId;
      }

      match /mic_seats/{seatId} {
          allow read: if request.auth != null;
          // Allow users to take a seat, or for admins to manage seats.
          allow write: if request.auth.uid == request.resource.data.userId || 
                         request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.ownerId;
          allow delete: if request.auth.uid == resource.data.userId || 
                         request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.ownerId;
      }

      match /mic_invites/{inviteId} {
          allow create: if request.auth.uid == request.resource.data.fromUserId;
          allow read, delete: if request.auth.uid == resource.data.toUserId || request.auth.uid == resource.data.fromUserId;
      }
    }

    // 4. Notifications Collection
    // READ: Only the recipient can read their notification.
    // WRITE: Denied from client. Should only be written by Cloud Functions.
    match /notifications/{notificationId} {
      allow read: if request.auth.uid == resource.data.to;
      allow write: if false;
    }

    // 5. Stories
    match /stories/{storyId} {
        allow read: if request.auth != null;
        allow create: if request.auth.uid == request.resource.data.userId;
        allow update: if request.auth.uid == resource.data.userId; // e.g., adding viewers
        allow delete: if request.auth.uid == resource.data.userId;
    }

    // 6. Posts
    match /posts/{postId} {
        allow read: if request.auth != null;
        allow create: if request.auth.uid == request.resource.data.authorId;
        allow update, delete: if request.auth.uid == resource.data.authorId;

        match /comments/{commentId} {
            allow read: if request.auth != null;
            allow create: if request.auth.uid == request.resource.data.userId;
            allow delete: if request.auth.uid == resource.data.userId || request.auth.uid == get(/databases/$(database)/documents/posts/$(postId)).data.authorId;
        }
    }

    // System settings - read-only for clients
    match /system_settings/global {
        allow read: if request.auth != null;
        allow write: if false; // Only admins from backend
    }
  }
}
